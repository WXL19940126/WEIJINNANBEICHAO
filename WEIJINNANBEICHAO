const dc={'西晋':'#e74c3c','东晋':'#2ecc71','十六国':'#f39c12','北魏':'#3498db','南朝':'#1abc9c','北朝':'#9b59b6'};

function initMap(){
  map=L.map('map',{center:[35,112],zoom:5,zoomControl:true,attributionControl:false});
  baseLayers.osm=L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:13}).addTo(map);
  baseLayers.dark=L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:13});
  baseLayers.topo=L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',{maxZoom:13});
  baseLayers.sat=L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{maxZoom:13});
  showAllMarkers();
  document.querySelectorAll('.base-btn').forEach(btn=>btn.addEventListener('click',()=>switchBase(btn.dataset.base)));
}

function switchBase(name){
  if(!baseLayers[name])return;
  currentBase=name;
  document.querySelectorAll('.base-btn').forEach(b=>b.classList.toggle('active',b.dataset.base===name));
  Object.values(baseLayers).forEach(l=>map.removeLayer(l));
  baseLayers[name].addTo(map);
}

function showAllMarkers(){
  markers.forEach(m=>map.removeLayer(m)); markers=[];
  Object.entries(HISTORICAL_PLACES).forEach(([name,info])=>{
    const c=dc[info.dynasty[0]]||'#d4a574';
    const icon=L.divIcon({className:'',html:'<div style="background:'+c+';width:9px;height:9px;border-radius:50%;border:1.5px solid #f5deb3;box-shadow:0 0 5px '+c+';"></div>',iconSize:[12,12],iconAnchor:[6,6]});
    const m=L.marker([info.lat,info.lng],{icon}).addTo(map);
    m.bindPopup('<div class="map-popup"><h4>'+name+'</h4><p>'+info.desc+'</p><p style="color:#8B7355;font-size:10px;margin-top:2px;">'+info.dynasty.join(' · ')+'</p></div>');
    markers.push(m);
  });
  if(markers.length)map.fitBounds(L.featureGroup(markers).getBounds().pad(0.08),{maxZoom:6});
}

function showMarkers(dynasties,foundPlaces){
  markers.forEach(m=>map.removeLayer(m)); markers=[];
  const toShow=new Set();
  if(activeLayer==='all'){
    for(const d of dynasties)toShow.add(d);
    if(foundPlaces&&foundPlaces.size>0)for(const p of foundPlaces)if(HISTORICAL_PLACES[p])toShow.add(p);
  }else{
    for(const[n,i]of Object.entries(HISTORICAL_PLACES))if(i.dynasty.includes(activeLayer))toShow.add(n);
  }
  toShow.forEach(name=>{
    const info=HISTORICAL_PLACES[name]; if(!info)return;
    const c=dc[info.dynasty[0]]||'#d4a574';
    const icon=L.divIcon({className:'',html:'<div style="background:'+c+';width:9px;height:9px;border-radius:50%;border:1.5px solid #f5deb3;box-shadow:0 0 5px '+c+';"></div>',iconSize:[12,12],iconAnchor:[6,6]});
    const m=L.marker([info.lat,info.lng],{icon}).addTo(map);
    m.bindPopup('<div class="map-popup"><h4>'+name+'</h4><p>'+info.desc+'</p><p style="color:#8B7355;font-size:10px;margin-top:2px;">'+info.dynasty.join(' · ')+'</p></div>');
    markers.push(m);
  });
  if(markers.length)map.fitBounds(L.featureGroup(markers).getBounds().pad(0.1),{maxZoom:7});
}

function switchLayer(layer){
  activeLayer=layer;
  document.querySelectorAll('.layer-btn').forEach(b=>b.classList.toggle('active',b.dataset.layer===layer));
  showMarkers(activeVol>=0?(DYNASTY_TAGS[INDEX_DATA[activeVol].key]||[]):[]);
  document.getElementById('map-legend').textContent='📍 '+(layer==='all'?'魏晋南北朝全部':DYNASTY_MAP[layer]||layer);
}

function buildTOC(){
  const p=document.getElementById('toc-panel'),t=document.getElementById('dynasty-timeline');
  p.innerHTML='';t.innerHTML='';
  const ac=document.createElement('span');ac.className='dynasty-chip';ac.textContent='全部时期';
  ac.addEventListener('click',()=>{
    activeVol=-1;activeChIdx=-1;
    document.querySelectorAll('.dynasty-chip').forEach(e=>e.classList.remove('active'));
    ac.classList.add('active');activeLayer='all';
    document.querySelectorAll('.layer-btn').forEach(b=>b.classList.toggle('active',b.dataset.layer==='all'));
    showAllMarkers();
    document.getElementById('map-legend').textContent='📍 魏晋南北朝全部 · 246处';
  });
  t.appendChild(ac);
  INDEX_DATA.forEach((vol,vi)=>{
    const chip=document.createElement('span');chip.className='dynasty-chip';
    chip.textContent=DYNASTY_MAP[vol.key]||vol.title;
    chip.addEventListener('click',()=>selectDynasty(vi));t.appendChild(chip);
    const sec=document.createElement('div');sec.className='vol-section';
    const hdr=document.createElement('div');hdr.className='vol-header';hdr.id='vol-'+vi;
    hdr.innerHTML='<span class="vol-title">'+vol.title+'</span><span class="vol-count">'+vol.chapter_count+'回</span>';
    hdr.addEventListener('click',()=>toggleVolume(vi));
    const cd=document.createElement('div');cd.className='vol-chapters';cd.id='chapters-'+vi;
    vol.chapters.forEach((ch,ci)=>{
      const item=document.createElement('div');item.className='chapter-item';item.id='ch-'+vi+'-'+ci;
      item.innerHTML='<span class="chapter-num">第'+ch.num+'回</span>'+ch.title;
      item.addEventListener('click',e=>{e.stopPropagation();selectChapter(vi,ci);});
      cd.appendChild(item);
    });
    sec.appendChild(hdr);sec.appendChild(cd);p.appendChild(sec);
  });
}

function toggleVolume(vi){
  document.querySelectorAll('.vol-chapters.open').forEach(e=>e.classList.remove('open'));
  document.querySelectorAll('.vol-header.active').forEach(e=>e.classList.remove('active'));
  document.getElementById('chapters-'+vi).classList.add('open');
  document.getElementById('vol-'+vi).classList.add('active');
  selectDynasty(vi);
}

function selectDynasty(vi){
  activeVol=vi;activeChIdx=-1;
  document.querySelectorAll('.dynasty-chip').forEach((e,i)=>e.classList.toggle('active',i===vi+1));
  document.querySelectorAll('.vol-header').forEach((e,i)=>e.classList.toggle('active',i===vi));
  document.querySelectorAll('.vol-chapters').forEach((e,i)=>e.classList.toggle('open',i===vi));
  document.querySelectorAll('.chapter-item').forEach(e=>e.classList.remove('active'));
  showMarkers(DYNASTY_TAGS[INDEX_DATA[vi].key]||[]);
  document.getElementById('map-legend').textContent='📍 '+(DYNASTY_MAP[INDEX_DATA[vi].key]||'')+' 历史地点';
}

async function selectChapter(vi,ci){
  activeVol=vi;activeChIdx=ci;
  const vol=INDEX_DATA[vi],ch=vol.chapters[ci];
  document.querySelectorAll('.vol-chapters').forEach(e=>e.classList.remove('open'));
  document.getElementById('chapters-'+vi).classList.add('open');
  document.querySelectorAll('.chapter-item').forEach(e=>e.classList.remove('active'));
  const el=document.getElementById('ch-'+vi+'-'+ci);
  if(el){el.classList.add('active');el.scrollIntoView({behavior:'smooth',block:'nearest'});}
  showMarkers(DYNASTY_TAGS[vol.key]||[]);
  document.getElementById('map-legend').textContent='📍 '+(DYNASTY_MAP[vol.key]||'')+' 历史地点';
  document.getElementById('welcome-screen').style.display='none';
  document.getElementById('chapter-view').style.display='none';
  document.getElementById('loading-screen').style.display='flex';
  document.getElementById('chapter-title').textContent='第'+ch.num+'回 '+ch.title;
  document.getElementById('chapter-vol-ref').textContent=vol.title;
  renderContent(VOL_DATA[ch.num_int]||'');
}

function renderContent(content){
  document.getElementById('loading-screen').style.display='none';
  document.getElementById('chapter-view').style.display='block';
  const ps=content.split('\n');
  let html='';const fp=new Set();
  for(let i=0;i<ps.length;i++){
    let p=ps[i];
    if(!p.trim())continue;
    p=p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    // Detect section titles: short line (4-30 chars) followed by blank line, no 。，！？结尾
    const isSectionTitle = p.trim().length>=4 && p.trim().length<=30
      && !/[。，！？；：、]$/.test(p.trim())
      && i+1<ps.length && !ps[i+1].trim();
    for(const n of placeNames){
      if(p.includes(n)){fp.add(n);
        const re=new RegExp(n.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'g');
        p=p.replace(re,'<span class="place-highlight" data-place="'+n+'" title="'+HISTORICAL_PLACES[n].desc+'">$&</span>');
      }
    }
    if(isSectionTitle)html+='<p class="section-title">'+p.trim()+'</p>';
    else html+='<p>'+p+'</p>';
  }
  document.getElementById('chapter-content').innerHTML=html;
  if(fp.size>0){
    showMarkers(DYNASTY_TAGS[INDEX_DATA[activeVol].key]||[],fp);
    document.getElementById('map-legend').textContent='📍 '+(DYNASTY_MAP[INDEX_DATA[activeVol].key]||'')+' · 提及'+fp.size+'处';
  }
  document.querySelectorAll('.place-highlight').forEach(el=>{
    el.addEventListener('click',function(){
      const info=HISTORICAL_PLACES[this.dataset.place];
      if(info&&map){map.setView([info.lat,info.lng],7,{animate:true});
        markers.forEach(m=>{const ll=m.getLatLng();if(Math.abs(ll.lat-info.lat)<0.03&&Math.abs(ll.lng-info.lng)<0.03)m.openPopup();});
      }
    });
  });
  document.getElementById('center-panel').scrollTop=0;
}

function initLayerSwitcher(){
  document.querySelectorAll('.layer-btn').forEach(btn=>btn.addEventListener('click',()=>switchLayer(btn.dataset.layer)));
}
function initSearch(){
  const inp=document.getElementById('search-input');let t;
  inp.addEventListener('input',()=>{
    clearTimeout(t);t=setTimeout(()=>{
      const q=inp.value.trim();if(q.length<2){document.getElementById('search-count').textContent='';return;}
      const r=[];INDEX_DATA.forEach((vol,vi)=>vol.chapters.forEach((ch,ci)=>{if(ch.title.includes(q))r.push({vi,ci});}));
      document.getElementById('search-count').textContent=r.length?'找到'+r.length+'条':'无结果';
      if(r.length){selectDynasty(r[0].vi);selectChapter(r[0].vi,r[0].ci);}
    },400);
  });
}
function initKeyboard(){
  document.addEventListener('keydown',e=>{
    if(e.target.tagName==='INPUT')return;
    if(activeVol<0||activeChIdx<0)return;
    const vol=INDEX_DATA[activeVol];let vi=activeVol,ci=activeChIdx;
    if(e.key==='ArrowDown'||e.key==='j'){ci++;if(ci>=vol.chapters.length){ci=0;vi=(vi+1)%INDEX_DATA.length;}}
    else if(e.key==='ArrowUp'||e.key==='k'){ci--;if(ci<0){vi=(vi-1+INDEX_DATA.length)%INDEX_DATA.length;ci=INDEX_DATA[vi].chapters.length-1;}}
    else if(e.key==='ArrowRight'){vi=(vi+1)%INDEX_DATA.length;ci=0;}
    else if(e.key==='ArrowLeft'){vi=(vi-1+INDEX_DATA.length)%INDEX_DATA.length;ci=0;}
    else return;
    selectDynasty(vi);selectChapter(vi,ci);
  });
}
document.addEventListener('DOMContentLoaded',()=>{
  buildTOC();initMap();initLayerSwitcher();initSearch();initKeyboard();
  setTimeout(()=>selectDynasty(0),400);
});
</script>
</body>
</html>
